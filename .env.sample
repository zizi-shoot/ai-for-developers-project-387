# Обязательный порт единого приложения при запуске через Docker (1024-65535).
PORT=

# Адрес, на котором backend принимает HTTP-запросы (host:port).
HTTP_ADDR=

# Разрешённые origins frontend через запятую.
CORS_ALLOWED_ORIGINS=

# Базовый URL API, используемый frontend.
VITE_API_BASE_URL=

# Адрес backend для локального proxy Vite.
API_PROXY_TARGET=
